{
	"servers": {
		"mui-mcp": {
			"type": "stdio",
			"command": "bunx",
			"args": [
				"-y",
				"@mui/mcp@latest"
			]
		},
		"awesome-copilot": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:latest"
			]
		},
		"gopls-mcp": {
			"type": "http",
			"url": "http://localhost:8092"
		},
		"chrome-devtools": {
			"command": "bunx",
			"args": [
				"chrome-devtools-mcp@latest"
			],
			"type": "stdio"
		},
		"sqlite": {
			"command": "bunx",
			"args": [
				"-y",
				"@executeautomation/database-server",
				"/mnt/remote/config.db3"
			],
			"type": "stdio"
		},
		"bun": {
			"command": "bunx",
			"args": [
				"-y",
				"mcp-bun@latest"
			],
			"env": {
				"DISABLE_NOTIFICATIONS": "true"
			},
			"type": "stdio"
		},
		"act-testing": {
			"command": "bunx",
			"args": [
				"act-testing-mcp"
			],
			"env": {
				"PROJECT_ROOT": "/workspaces/srat"
			},
			"type": "stdio"
		},
		"vale-mcp": {
			"type": "stdio",
			"command": "bunx",
			"args": [
				"-y",
				"@iflow-mcp/chrischinchilla-vale-mcp"
			]
		},
		"mise": {
			"type": "stdio",
			"command": "mise",
			"args": [
				"mcp"
			],
			"env": {
				"MISE_EXPERIMENTAL": "1"
			}
		}
	}
}