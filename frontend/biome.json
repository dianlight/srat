{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"extends": "//",
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"src/**/*.ts",
			"src/**/*.tsx",
			"!src/store/sratApi.ts",
			"!src/mocks",
			"!src/**/*.test.*",
			"!test/setup.ts"
		]
	},
	"formatter": {
		"enabled": true
	},
	"javascript": {
		"formatter": {
			"enabled": true
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}